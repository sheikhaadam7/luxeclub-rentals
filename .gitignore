# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local dev scratch — email previews, color picker, etc.
/tmp/

# Car-type spreadsheet workflow (scripts/export-car-types.py +
# scripts/import-car-types.py). Generated on demand from Supabase; not source
# of truth for the catalogue. Backups are written before every --apply.
/data/car-types.xlsx
/data/car-types-backup-*.csv
